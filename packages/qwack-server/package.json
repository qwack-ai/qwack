{
  "name": "@qwack/server",
  "version": "0.1.0-alpha",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "QWACK_DEV=true bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1012.0",
    "@aws-sdk/lib-dynamodb": "3.1012.0",
    "@neondatabase/serverless": "^0.10.0",
    "@openauthjs/openauth": "latest",
    "@qwack/shared": "workspace:*",
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.10.0",
    "lib0": "^0.2.0",
    "ulid": "^2.3.0",
    "valibot": "^1.0.0",
    "y-protocols": "^1.0.0",
    "y-websocket": "^2.0.0",
    "yjs": "^13.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@qwack/plugin": "workspace:*",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-jest": "4.1.0",
    "bun-types": "latest",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
